# ─── Сервер (apps/api) ───────────────────────────────────────────────
# Токен Telegram-бота. Нужен для проверки initData и пуш-уведомлений.
# ВАЖНО: пока не задан — сервер работает в dev-режиме и пускает любого
# по заголовку X-Dev-User. Для публичного запуска обязателен.
BOT_TOKEN=

# Путь к файлу БД (SQLite). По умолчанию ./data/game.db относительно apps/api
DB_PATH=./data/game.db

PORT=8080
HOST=0.0.0.0

# Домены, которым разрешён доступ к API (через запятую).
# Нужно, когда мини-апп на GitHub Pages, а API — на другом хосте.
# Пусто = разрешён любой origin (годится только для разработки).
ALLOWED_ORIGINS=

# Публичный адрес мини-аппа (для deep-links и шаринга реплеев)
PUBLIC_URL=https://example.com

# Принудительно включить dev-авторизацию даже при заданном BOT_TOKEN. Не для прода.
DEV_AUTH=

LOG_LEVEL=info

# ─── Сборка мини-аппа (apps/web) ─────────────────────────────────────
# Базовый адрес API. Пусто = тот же origin (когда API сам раздаёт статику).
VITE_API_URL=

# Подпуть, по которому раздаётся статика. Для GitHub Pages — /<имя-репозитория>/
VITE_BASE=/
